POSTGRES_DSN=postgresql+asyncpg://postgres:postgres@localhost:5432/sre_agent
REDIS_URL=redis://localhost:6379/0
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
POLICY_DEFAULT_MODE=review_required
AUTONOMY_KILL_SWITCH=true
INCIDENT_RETENTION_DAYS=180
OTEL_ENABLED=true
LOG_LEVEL=INFO
CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:5175

# Agentic AI (LLM) — server-side ONLY (never in Vite / browser).
# Copy to .env, set LLM_API_KEY, restart router (8003).
AGENTIC_ENABLED=true
# When false and AGENTIC_ENABLED=true, LLM errors do not fall back to static stub logic (strict agentic mode).
AGENTIC_STUB_FALLBACK=true

# OpenAI (default for this project)
LLM_BASE_URL=https://api.openai.com/v1
# Examples: gpt-4o-mini, gpt-4o, gpt-5.4-mini — pick what your account supports.
# For gpt-5.* on api.openai.com the client sends max_completion_tokens and reasoning_effort=none automatically.
LLM_MODEL=gpt-5.4-mini

# Required for api.openai.com; leave empty only for local Ollama with no key
# Set in your local .env only — never commit real keys (use a placeholder in templates).
LLM_API_KEY=
# Local Ollama (no key) — uncomment and adjust if not using OpenAI:
# LLM_BASE_URL=http://127.0.0.1:11434/v1
# LLM_MODEL=llama3.2
# LLM_API_KEY=

LLM_TIMEOUT_SECONDS=60
LLM_MAX_TOKENS=2048
LLM_MAX_CALLS_PER_ROUTE=20
LLM_MAX_TOKENS_PER_ROUTE=100000

# Adapters: stub | (extend for real backends)
TELEMETRY_ADAPTER=stub
CHANGE_FEED_ADAPTER=stub

# Defense-in-depth: route privileged actions through sandbox wrapper
SANDBOX_ENABLED=true

# Decision loop (OpenClaw-style): observe -> decide -> act -> verify
ROUTER_DECISION_LOOP_ENABLED=false
ROUTER_MAX_ITERATIONS=12
ROUTER_LLM_ENABLED=false
WORKING_MEMORY_ENABLED=true
BLOCK_EXECUTE_WHEN_INVESTIGATE_ONLY=true
EXECUTE_ACTION_DRY_RUN=false
EXECUTE_POST_VERIFY_ENABLED=true
PLANNER_DEFAULT_DRY_RUN=false
