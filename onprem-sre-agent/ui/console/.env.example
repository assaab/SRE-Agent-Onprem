# Optional: override API bases for production or non-default ports.
# Copy to .env in this folder (ui/console) if you need custom URLs.
# Leave unset during `npm run dev` to use same-origin /api/* proxies (avoids CORS / Failed to fetch).
# VITE_INCIDENT_STORE_URL=http://localhost:8002
# VITE_AUDIT_URL=http://localhost:8006
# VITE_ROUTER_URL=http://localhost:8003
# VITE_APPROVAL_URL=http://localhost:8005
# Optional: proxy targets if backends are not on localhost defaults (dev only):
# VITE_APPROVAL_PROXY_TARGET=http://127.0.0.1:8005
